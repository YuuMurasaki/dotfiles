#!/bin/sh

# Define the screenshots directory
dir="$HOME/Pictures/Screenshots"

# Create screenshot folder if not found
[ ! -d "$dir" ] && mkdir -p "$dir"

# Generate name
timeee=$(date '+%Y-%m-%d_%H-%M-%S')

# Take screenshot
case "$1" in
	"crop") maim --select --hidecursor "$dir/$timeee.png" ;;
	"full") maim --hidecursor "$dir/$timeee.png" ;;
	*) exit 1 ;;
esac
