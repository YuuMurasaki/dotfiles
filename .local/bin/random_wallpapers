#!/bin/sh

# This script applies random wallpapers from $HOME/Pictures/wallpapers
# NOTE: The file types of the selected wallpaper and the target file must match.
# For example, if the selected wallpaper is a .jpg, the target file should also
# have a .jpg extension. Copying a .jpg to a .png may cause unexpected behavior.

# Directory where all wallpapers are in
dir="$HOME/Pictures/wallpapers"
[ ! -d "$dir" ] && exit 1

currentWall="$HOME/.local/share/wallpapers/wallpaper.png"

# Select a random wallpaper
selectWall=$( find "$dir" -type f | shuf --head-count=1 )

# Apply the wallpaper
xwallpaper --zoom $selectWall
cp $selectWall $currentWall
