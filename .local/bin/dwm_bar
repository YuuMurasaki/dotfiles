#!/bin/sh

mem() {
    memoryUsage=$(free -h | awk '/^Mem:/ { print $3 "/" $2 }')
    printf "о‰¦ $memoryUsage"
}

show_volume() {
    volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | tr -dc '0-9' | sed 's/^0\{1,2\}//')
    printf "%s%%\n" "пЂЁ $volume"
}

wifi() {
    wifiicon="п†“"

    # WiFi
    [ "$(cat /sys/class/net/wl*/operstate 2>/dev/null)" = 'up' ] && wifiicon="$(awk '/^\s*w/ { print "п‡«", int($3 * 100 / 70) "%" }' /proc/net/wireless)"

    printf "%s" "$wifiicon"
}

ethernet() {
    ethericon="п†“"

    # Ethernet
    [ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethericon="п‚¬"

    printf "$ethericon"
}

clock() {
    timeee=$(date +"%H:%M")
    printf "пЂ— $timeee"
}

calendar() {
    todayyy=$(date +"%d %b %Y")
    printf "п„і $todayyy"
}

while true; do
    xsetroot -name "$(show_volume) | $(wifi) | $(ethernet) | $(clock) | $(calendar)"
    sleep 2
done
