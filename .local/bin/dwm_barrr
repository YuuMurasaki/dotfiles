#!/bin/sh

cpu() {
    cpuUsage=$(grep -o "^[^ ]*" /proc/loadavg)
    printf " $cpuUsage"
}

mem() {
    memoryUsage=$(free --human | awk '/^Mem:/ { print $3 "/" $2 }')
    printf " $memoryUsage"
}

wlan() {
    wifiicon=""
    ethericon=""

    # WiFi
    [ "$(cat /sys/class/net/wl*/operstate 2>/dev/null)" = 'up' ] && wifiicon="$(awk '/^\s*w/ { print " ", int($3 * 100 / 70) "%" }' /proc/net/wireless)"

    # Ethernet
    [ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethericon=""

    printf "%s %s" "$wifiicon" "$ethericon"
}

clock() {
    timeee=$(date +"%H:%M")
    printf " $timeee"
}

calendar() {
    todayyy=$(date +"%d %b %Y")
    printf " $todayyy"
}

while true; do
    xsetroot -name "$(mem) | $(wlan) | $(clock) | $(calendar)"
    sleep 2
done
