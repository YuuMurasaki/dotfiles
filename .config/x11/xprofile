#!/bin/sh

# This file runs when a DM logs you into a graphical session.
# Add programs which you want to run after logging in

# Use xrandr to set screen resolution
xrandr --output "LVDS-1" --mode "1366x768"

# Set wallpaper
xwallpaper --zoom $HOME/.local/share/wallpapers/girl-2.jpg

# Hide mouse cursor after 3 sec.
unclutter --root --timeout 3 &

# Start dwmblocks
#dwmblocks &
