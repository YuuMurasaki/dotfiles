# Path
export PATH="$HOME/.local/bin:$PATH"

# Program variables
export BROWSER="firefox"
export EDITOR="nvim"
export TERM="xterm-256color"
export TERMINAL="st"
export READER="zathura"
export PAGER="less"

# Automatically start window manager in tty
[ "$(tty)" = "/dev/tty1" ] && ! pidof -s Xorg >/dev/null 2>&1 && exec startx
