#!/bin/sh

# Custom alias and commands

# Core Utilities
alias df="df -hT"
alias du="du -hs"
alias cp="cp -iv"
alias mv="mv -iv"
alias rm="rm -v"
alias ip="ip -c -h"
alias free="free -hw"
alias grep="grep --color=auto"
alias ls="ls --color=auto --group-directories-first -AF"
alias ll="ls --color=auto -lhAF"

# Better cd
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Packages manager
alias update="doas xbps-install -Syu && doas reboot"
alias install="doas xbps-install -Sy"
alias remove="doas xbps-remove \$(xbps-query -l | cut -d ' ' -f2 | fzf)"
alias clean="doas xbps-remove -Oo"

# Git
alias ggg="git status"
alias ggp="git push"
alias ggc="git commit --verbose"
alias ggs="git show \$(git log --oneline | fzf | cut -d ' ' -f1)"

# Commands
playmp3() {
    setsid -f \
        mpv --player-operation-mode=pseudo-gui \
            --shuffle --af=lavfi="acompressor" \
            --no-terminal -- ./*.mp3
}

mkd() {
    mkdir -pv "$1" && cd "$1" || exit 1
}
