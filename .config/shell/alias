#!/bin/sh

# Custom alias and commands file

# Packages
alias pkgupdate='doas apt update && apt upgrade -y'
alias pkginstall='doas apt-get install'
alias pkgclean='doas apt-get autoremove'
alias pkgremove='doas apt-get remove'
alias pkgsearch='apt search'
alias pkglist='dpkg -l'

# System
alias top='htop'
alias cpu='ps aux | sort -r -nk +4 | head | $PAGER'
alias cpuinfo='lscpu | $PAGER'

# Easier to read
alias df='command df -h'
alias du='command du -h'
alias free='command free -h'

# Move, copy and remove
alias cp='cp -i'
alias mv='mv -i'

# Colorize commands when possible.
alias dmesg='dmesg --color'
alias grep='grep --color=auto'
alias diff='diff --color=auto'

# Change directory aliases
alias docs='cd $HOME/Documents'
alias down='cd $HOME/Downloads'
alias music='cd $HOME/Music'
alias pics='cd $HOME/Pictures'
alias videos='cd $HOME/Videos'
alias config='cd $HOME/.config'
alias CONFIG='cd /etc'
alias fonts='cd $HOME/.local/share/fonts'
alias bin='cd $HOME/.local/bin'
alias BIN='cd /bin'

# Better cd
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'

# Better ls (Eza) [https://eza.rocks]
#alias ls="command eza --all --classify --color=auto --color-scale=all --icons=auto --group-directories-first"
#alias ll="command eza --all --classify --color=auto --color-scale=all --icons=auto --group-directories-first --long --links --smart-group --modified"
#alias lr="command eza --all --classify --color=auto --color-scale=all --icons=auto --group-directories-first --grid --recurse"
#alias lt="command eza --all --classify --color=auto --color-scale=all --icons=auto --group-directories-first --header --long --tree"

# Better ls
alias ls="ls -aF --color=auto --group-directories-first"
alias ll="ls -aF --color=auto --group-directories-first -lh"
alias lr="ls -aF --color=auto --group-directories-first -R"

# History
alias clearhis='cat /dev/null > ${XDG_CACHE_HOME:-$HOME/.cache}/yash/history'

# Git
alias ggg='git status --untracked-files=no'
alias ggs='git status'
alias ggall='git add --update'
alias gga='git add'
alias ggc='git commit --verbose -m'

# Networking
alias iplocal="ifconfig | grep -Eo 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -Eo '([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1'"
alias ping='ping -c 5'

# Date and time
alias today='date +"%Y-%m-%d"'
alias now='date +"%T"'

############################################
############### FZF COMMANDS ###############
############################################

fcd() {
    local dir=$( fdfind --type d --max-depth 5 --hidden 2>/dev/null | fzf )
    if [ -n "$dir" ]; then
        cd "$dir" || return
    fi
}

fvi() {
    local files=$( fdfind --type f --hidden 2>/dev/null | fzf )
    if [ -n "$files" ]; then
        nvim "$files" || return
    fi
}

fhis() {
    eval $( history | fzf --no-sort --tac --height=70% | sed -E 's/ *[0-9]*\*? *//' | sed -E 's/\\/\\\\/g' )
}
