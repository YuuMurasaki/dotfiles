#!/bin/sh

# Custom alias and commands

# Core Utilities
alias df="df -hT"
alias du="du -hs"
alias free="free -h"
alias cp="cp -iv"
alias mv="mv -iv"

# Better cd
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

# Better ls
alias ls="ls --color=auto -AF"
alias ll="ls --color=auto -lhAF"

# Commands
playmp3() {
    setsid -f \
        mpv --player-operation-mode=pseudo-gui \
            --shuffle --af=lavfi="acompressor" \
            --no-terminal -- ./*.mp3
}
